{
  "name": "booking-graph-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "build": "nest build",
    "start": "node dist/main.js",
    "seed": "ts-node src/scripts/seed.ts",
    "seed:dev": "NODE_ENV=development pnpm run seed",
    "sync:elasticsearch": "ts-node src/scripts/sync-elasticsearch.ts",
    "sync:elasticsearch:dev": "NODE_ENV=development ts-node src/scripts/sync-elasticsearch.ts",
    "db:migrate": "npx sequelize-cli --config ./src/database/config/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders db:migrate",
    "db:migrate:undo": "npx sequelize-cli --config ./src/database/config/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders db:migrate:undo",
    "db:seed": "npx sequelize-cli --config ./src/database/config/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders db:seed:all",
    "db:seed:undo": "npx sequelize-cli --config ./src/database/config/config.js --migrations-path ./src/database/migrations --seeders-path ./src/database/seeders db:seed:undo:all",
    "db:reset": "pnpm run db:migrate:undo && pnpm run db:seed:undo && pnpm run db:migrate && pnpm run db:seed",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --config jest.config.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@elastic/elasticsearch": "^8.19.1",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@types/bcrypt": "^6.0.0",
    "@types/handlebars": "^4.0.40",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "graphql": "^16.13.2",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4"
  }
}
