# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_password_here
DB_NAME=booking_db

# Application Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# API Configuration
API_PREFIX=api

# JWT Configuration (for future authentication)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key  
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Instructions:
# 1. Replace 'your-cloudinary-cloud-name' with your actual Cloudinary cloud name
# 2. Replace 'your-cloudinary-api-key' with your actual API key
# 3. Replace 'your-cloudinary-api-secret' with your actual API secret
# 4. Create a .env file in your project root with these values

# Logging
LOG_LEVEL=info
